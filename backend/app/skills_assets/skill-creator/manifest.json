{
  "id": "skill-creator",
  "version": "1.0.0",
  "name": "技能创建器",
  "display_name": "创建技能",
  "description": "根据自然语言需求自动创建可运行技能模板并落盘到 skills_assets。",
  "category": "developer",
  "status": "ready",
  "author": "@SkillCreator",
  "tags": [
    "技能创建",
    "自动化",
    "MVP"
  ],
  "entrypoints": {
    "standalone": true,
    "chat_invoke": false,
    "external_api": false
  },
  "triggers": {
    "mention_ids": [
      "skill-creator"
    ],
    "mention_aliases": [
      "创建技能"
    ]
  },
  "execution": {
    "mode": "agent_workflow",
    "agent_id": "skill-creator",
    "driver": "claude_code"
  },
  "input_schema": {
    "type": "object",
    "required": [
      "query"
    ],
    "properties": {
      "query": {
        "type": "string",
        "title": "技能需求",
        "description": "描述你想创建的技能能力、流程和交付物"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "summary",
      "created_skill_id",
      "artifact_root"
    ],
    "properties": {
      "summary": {
        "type": "string"
      },
      "created_skill_id": {
        "type": "string"
      },
      "artifact_root": {
        "type": "string"
      }
    }
  },
  "permissions": [
    "filesystem:skills_assets.write",
    "filesystem:skills_assets.read"
  ],
  "ui": {
    "theme_accent": "#F59E0B",
    "chat_card": {
      "show_fields": [
        "query"
      ],
      "allow_file_upload": false
    },
    "standalone": {
      "show_trace": true,
      "show_export": false
    }
  },
  "icon": "Sparkle",
  "internal": true,
  "source": "system_internal"
}

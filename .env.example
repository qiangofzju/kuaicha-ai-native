# ============================
# 快查 AI 环境变量配置
# ============================
# 复制此文件为 .env.local 后修改

# Agent 驱动: "mock" (默认, 无需 Claude) | "cli" (Claude Code CLI) | "api" (Anthropic API)
AGENT_DRIVER=mock

# Claude 模型 (cli/api 模式)
CLAUDE_MODEL=sonnet

# Anthropic API Key (仅 api 模式需要)
ANTHROPIC_API_KEY=

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=3000

# 前端 → 后端 URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mock 数据
USE_MOCK_DATA=true

# 工作区根目录 (空=默认: 项目根/data/workspaces)
WORKSPACE_ROOT=
